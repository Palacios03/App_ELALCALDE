<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme: no action bar, no title, black background -->
    <style name="Theme.MediaScroll" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Theme for FolderPickerActivity -->
    <style name="Theme.MediaScroll.FolderPicker" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#0D0D0D</item>
        <item name="android:colorPrimary">#FF3B3B</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:navigationBarColor">#0D0D0D</item>
    </style>

</resources>
